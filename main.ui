  <widget class="QWidget" name="styleSheet">
   <property name="styleSheet">
    <string notr="true">/*
Dark theme for sapr
*/

QWidget{
	color: rgb(221, 221, 221);
	font: 10pt &quot;Segoe UI&quot;;
}

/* App backgound */
#appBg {
	background-color: rgb(49, 51, 56);
	border: 1px solid rgb(90, 90, 90);
	border-radius: 10px;
}

/* Toggle Menu */
#leftMenuBg {
	background-color: rgb(47, 47, 52);
}

/* Top logo */
#topLogo {
	background-color: rgb(47, 47, 52);
	background-image: url(:/Images/images/logo_medium.png);
	background-position: centered;
	background-repeat: no-repeat;
}

/* Top text */
#titleLeftApp { font: 63 14pt &quot;Segoe UI Semibold&quot;; }
#titleLeftDescription { font: 8pt &quot;Segoe UI&quot;; color: rgb(31, 158, 235); }

/* Top Content */
#contentTopBg {
	background-color: rgb(47, 47, 52);
	border-top-left-radius: 10px;
	border-top-right-radius: 10px;
}
#leftBox QLabel { color: rgb(235, 235, 235); padding-left: 10px; padding-right: 10px; padding-bottom: 2px;}

/* Top menu buttons (Файл, Правка, ...) */
#leftBox QPushButton {
	background-color: transparent;
	border: none;
	border-radius: 4px;
	color: rgb(180, 180, 180);
	padding: 0px 6px;
	text-align: center;
}
#leftBox QPushButton:hover {
	background-color: rgb(80, 80, 80);
	color: rgb(220, 220, 220);
}
#leftBox QPushButton:pressed {
	background-color: rgb(100, 100, 100);
	color: rgb(255, 255, 255);
}

/* Bottom content */
#contentBottom{
	border-top: 3px solid rgb(37, 38, 43);
}
#bottomBar {
	background-color: rgb(43, 43, 48);
	border-bottom-left-radius: 10px;
	border-bottom-right-radius: 10px;
}
#bottomBar QLabel { font-size: 11px; color: rgb(235, 235, 235); padding-left: 10px; padding-right: 10px; padding-bottom: 2px; }


/* Menus */
#topMenu .QPushButton {
	background-position: left center;
    background-repeat: no-repeat;
	border: none;
	border-left: 15px solid transparent;
	background-color: transparent;
	text-align: left;
	font-size: 12px;
	padding-left: 40px;
}
#topMenu .QPushButton:hover {
	background-color: rgb(80, 80, 80);
}
#topMenu .QPushButton:pressed {
	background-color: rgb(100, 100, 100);
	color: rgb(255, 255, 255);
}
#bottomMenu .QPushButton {
	background-position: left center;
    background-repeat: no-repeat;
	border: none;
	border-left: 15px solid transparent;
	background-color:transparent;
	text-align: left;
	font-size: 12px;
	padding-left: 40px;
}
#bottomMenu .QPushButton:hover {
	background-color: rgb(80, 80, 80);
}
#bottomMenu .QPushButton:pressed {
	background-color: rgb(100, 100, 100);
	color: rgb(255, 255, 255);
}

#leftMenuFrame {
	border-top: 3px solid rgb(37, 38, 43);
}

/* Toggle Button */
#toggleButton {
	background-position: left center;
    background-repeat: no-repeat;
	border: none;
	border-left: 15px solid transparent;
	background-color: rgb(47, 47, 52);
	text-align: left;
	font-size: 12px;
	padding-left: 40px;
	color: rgb(255, 255, 255);
}
#toggleButton:hover {
	background-color: rgb(80, 80, 80);
}
#toggleButton:pressed {
	background-color: rgb(100, 100, 100);
}

/* Top Right Buttons  */
#closeAppBtn {
	background-color: rgba(255, 255, 255, 0);
	border: none;
	border-top-right-radius: 10px;
}
#closeAppBtn:hover {
	background-color: rgb(207, 144, 145);
}
#closeAppBtn:pressed {
	background-color: rgb(241, 117, 119);
}

#maximizeRestoreAppBtn {
	background-color: rgba(255, 255, 255, 0);
	border: none;
}
#maximizeRestoreAppBtn:hover {
	background-color: rgb(80, 80, 80);
}
#maximizeRestoreAppBtn:pressed {
	background-color: rgb(100, 100, 100);
}

#minimizeAppBtn {
	background-color: rgba(255, 255, 255, 0);
	border: none;
}
#minimizeAppBtn:hover {
	background-color: rgb(80, 80, 80);
}
#minimizeAppBtn:pressed {
	background-color: rgb(100, 100, 100);
}

/* Theme for LineEdit*/
QLineEdit {
	background-color: rgb(33, 37, 43);
	border-radius: 5px;
	border: 2px solid rgb(33, 37, 43);
	padding-left: 10px;
	selection-color: rgb(255, 255, 255);
	selection-background-color: rgb(31, 158, 235);
}
QLineEdit:hover {
	border: 2px solid rgb(64, 71, 88);
}
QLineEdit:focus {
	border: 2px solid rgb(91, 101, 124);
}


#pagesContainer QPushButton {
	border: 2px solid rgb(52, 59, 72);
	border-radius: 5px;	
	background-color: rgb(52, 59, 72);
}
#pagesContainer QPushButton:hover {
	background-color: rgb(57, 65, 80);
	border: 2px solid rgb(61, 70, 86);
}
#pagesContainer QPushButton:pressed {
	background-color: rgb(35, 40, 49);
	border: 2px solid rgb(43, 50, 61);
}


/* ScrollBars */
QScrollBar:horizontal {
    border: none;
    background: rgb(52, 59, 72);
    height: 8px;
    margin: 0px 21px 0 21px;
	border-radius: 0px;
}
QScrollBar::handle:horizontal {
    background: rgb(61, 70, 86);
    min-width: 25px;
	border-radius: 4px
}
QScrollBar::add-line:horizontal {
    border: none;
    background: rgb(55, 63, 77);
    width: 20px;
	border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    subcontrol-position: right;
    subcontrol-origin: margin;
}
QScrollBar::sub-line:horizontal {
    border: none;
    background: rgb(55, 63, 77);
    width: 20px;
	border-top-left-radius: 4px;
    border-bottom-left-radius: 4px;
    subcontrol-position: left;
    subcontrol-origin: margin;
}
QScrollBar::up-arrow:horizontal, QScrollBar::down-arrow:horizontal
{
     background: none;
}
QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal
{
     background: none;
}
 QScrollBar:vertical {
	border: none;
    background: rgb(52, 59, 72);
    width: 8px;
    margin: 21px 0 21px 0;
	border-radius: 0px;
 }
 QScrollBar::handle:vertical {	
	background: rgb(61, 70, 86);
    min-height: 25px;
	border-radius: 4px
 }
 QScrollBar::add-line:vertical {
     border: none;
    background: rgb(55, 63, 77);
     height: 20px;
	border-bottom-left-radius: 4px;
    border-bottom-right-radius: 4px;
     subcontrol-position: bottom;
     subcontrol-origin: margin;
 }
 QScrollBar::sub-line:vertical {
	border: none;
    background: rgb(55, 63, 77);
     height: 20px;
	border-top-left-radius: 4px;
    border-top-right-radius: 4px;
     subcontrol-position: top;
     subcontrol-origin: margin;
 }
 QScrollBar::up-arrow:vertical, QScrollBar::down-arrow:vertical {
     background: none;
 }

 QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
     background: none;
 }

 /* CheckBox */
QCheckBox::indicator {
    border: 2px solid rgb(37, 38, 43);
	width: 18px;
	height: 18px;
	border-radius: 10px;
    background: rgb(47, 47, 52);
}
QCheckBox::indicator:hover {
    border: 2px solid rgb(47, 52, 61);
}
QCheckBox::indicator:checked {
    background: 3px solid rgb(26, 127, 189);
	border: 2px solid rgb(37, 41, 48);	
}</string>
